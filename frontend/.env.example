# Frontend environment (Vite). Copy to .env for local overrides.

# Where the app sends API calls. Defaults to "/api" (same-origin), which the
# dev Vite server and the prod nginx both reverse-proxy to the backend.
# Leave unset unless the backend is on a different origin.
# VITE_API_URL=/api

# Dev-only: the Vite dev-server proxy target for /api (see vite.config.js).
# Ignored by the production nginx image (Dockerfile.prod), which proxies to
# the "backend" service directly.
VITE_BACKEND_URL=http://127.0.0.1:8000
