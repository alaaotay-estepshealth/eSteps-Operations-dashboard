backend/.venv/
**/__pycache__/
*.pyc
.pytest_cache/

# ─── Node / Vite ───────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ─── Local-only docs (kept out of the public repo) ───────────────────────────
References/

# ─── Misc ──────────────────────────────────────────────────────────────────────
*.log
.DS_Store

