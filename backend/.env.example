# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:   postgresql://esteps:esteps123@localhost:5432/esteps_ops
# Supabase:    postgresql://postgres:[PASSWORD]@db.lsihimpxtahvnyjlqsix.supabase.co:6543/postgres?sslmode=require
#              Get password: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://esteps:esteps123@localhost:5432/esteps_ops

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── n8n Integration ──────────────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.estepshealth.tech
# Get from: https://n8n.estepshealth.tech/settings/api
N8N_API_KEY=your-n8n-api-key-here
# Fallback secret (overridden by per-system secret in DB)
N8N_WEBHOOK_SECRET=esteps-leads-fallback-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI Budget ────────────────────────────────────────────────────────────────
AI_DAILY_BUDGET_USD=10.0

# ─── Leads DB ─────────────────────────────────────────────────────────────────
# Read-only connection to eSteps Leads Automation Supabase (eu-central-1)
# Falls back to ops DB when empty
LEADS_DATABASE_URL=

# ─── GTM Strategy ─────────────────────────────────────────────────────────────
# Path to strategy markdown files directory (relative or absolute)
# Defaults to "Final planning/" in project root when empty
STRATEGY_DIR=

# ─── AI strategy memo / assistant (Gemini) ───────────────────────────────────
# Optional — enables the Insights AI memo + Ask-the-Assistant. Missing → those return 503.
GEMINI_API_KEY=

# ─── OpenClaw agent gateway ───────────────────────────────────────────────────
# Optional — enables launching agent actions from the dashboard (/agent).
# Enable hooks in OpenClaw (hooks.enabled=true) and use a dedicated hooks.token here.
OPENCLAW_BASE_URL=
OPENCLAW_HOOK_TOKEN=

# ─── Runtime ──────────────────────────────────────────────────────────────────
# development → HMAC skipped, auto-create tables enabled
# production  → HMAC enforced, no auto-create
ENVIRONMENT=development
AUTO_CREATE_DB=true
